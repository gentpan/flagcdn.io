{
  "manifest_version": 3,
  "name": "AI Bookmark Organizer",
  "version": "0.1.0",
  "description": "Use your own AI API token to analyze Chrome bookmarks and apply folder reorganization plans.",
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AI Bookmark Organizer",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
